<UserControl
    x:Class="Screenbox.Controls.DesktopLyricsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:converters="using:Screenbox.Converters"
    mc:Ignorable="d"
    d:DesignHeight="150"
    d:DesignWidth="800"
    Background="Transparent"
    PointerPressed="OnPointerPressed"
    PointerMoved="OnPointerMoved">

    <UserControl.Resources>
        <converters:UIntToColorBrushConverter x:Key="UIntToColorBrushConverter" />
    </UserControl.Resources>

    <Border
        x:Name="LyricsBorder"
        Padding="64,48"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="#60000000">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock
                x:Name="HighlightedTextBlock"
                MaxWidth="1000"
                HorizontalAlignment="Center"
                FontSize="{Binding FontSize}"
                FontWeight="Bold"
                Foreground="{Binding HighlightColor, Converter={StaticResource UIntToColorBrushConverter}, Mode=OneWay}"
                Text="{Binding HighlightedText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="RemainingTextBlock"
                MaxWidth="1000"
                HorizontalAlignment="Center"
                FontSize="{Binding FontSize}"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding RemainingText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>